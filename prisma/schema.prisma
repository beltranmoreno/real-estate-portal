// Portal database schema (Neon Postgres + Prisma).
//
// Source-of-truth split:
//   * Sanity owns property content, agent profiles, areas, etc.
//   * Postgres owns users, bookings, requests, documents, audit trails.
//   * The bridge between them is `propertySanityId` (string) — never
//     duplicate Sanity content into this DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Pooled URL for Prisma client (used at runtime by app routes).
  url       = env("DATABASE_URL")
  // Unpooled URL for migrations (Vercel/Neon expose both).
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------------------------------------------------------------------------
// Roles & status enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN              // Leticia — full access
  AGENT              // her team — admin minus user mgmt + sensitive financial
  STAFF              // schema-ready, no UI yet (housekeeping/concierge ops)
  OWNER              // schema-ready, no UI yet (homeowners)
  RENTER             // primary booking contact
  ADDITIONAL_GUEST   // future-proof: secondary guests on a booking
}

enum BookingStatus {
  PENDING            // booking exists, primary guest hasn't accepted invite
  CONFIRMED          // guest accepted & signed in
  ACTIVE             // currently in their stay
  COMPLETED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum RequestKind {
  // Document presets
  PASSPORT
  RENTAL_CONTRACT
  DEPOSIT_RECEIPT
  ID_PHOTO
  TRAVEL_INSURANCE
  PET_DOCUMENTATION
  // Information presets
  ARRIVAL_DETAILS
  GUEST_LIST
  DIETARY_PREFERENCES
  SERVICE_PREFERENCES
  // Free-form
  CUSTOM
}

enum RequestStatus {
  PENDING            // awaiting renter (initial state OR rejected)
  PENDING_REVIEW     // renter submitted, admin must accept/reject
  FULFILLED          // admin approved the submission
  WAIVED             // admin marked as not needed for this booking
  EXPIRED
}

enum DocumentKind {
  PASSPORT
  CONTRACT
  RECEIPT
  ID
  INSURANCE
  PET_DOC
  AGENT_UPLOAD       // anything Leticia uploads to share with renter
  OTHER
}

// Concierge service requests are conceptually distinct from `Request`:
// - `Request` = something WE need from the guest (passport, dietary prefs)
// - `ServiceRequest` = something the GUEST wants from us (chef, transfer, tee time)
// Different status arc, different audience, kept on a separate table.
enum ServiceRequestStatus {
  REQUESTED          // renter just submitted, admin hasn't touched it
  IN_PROGRESS        // admin is sourcing/coordinating
  CONFIRMED          // booked & scheduled
  COMPLETED
  DECLINED           // unable to fulfill
  CANCELLED          // renter or admin cancelled before completion
}

// Discriminator for the *type* of service request. Each kind uses a
// different subset of fields on the row (see comments on ServiceRequest).
enum ServiceRequestKind {
  SERVICE            // a concierge service from the Sanity catalog
  MENU               // a preset chef menu from the Sanity catalog
  GROCERY            // a grocery / drinks shopping list (groceryItems[])
  CUSTOM             // free-form (admin-logged out-of-band requests)
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  // Bridge field — Clerk handles auth, this is how we reconcile sessions
  // with our DB. Indexed for the every-request lookup.
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  phone     String?
  role      UserRole @default(RENTER)
  locale    String?  @default("en") // "en" | "es"

  // Admin-only freeform notes about a guest. Persists across bookings —
  // useful for things like dietary preferences, past behavior, or
  // "always asks for the corner room". Never shown to the renter.
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RENTER side
  bookingsAsPrimary Booking[]  @relation("BookingPrimaryGuest")
  uploadedDocs      Document[] @relation("UploadedBy")
  fulfilledReqs     Request[]  @relation("FulfilledBy")

  // ADMIN/AGENT side
  createdInvites  Invitation[] @relation("CreatedBy")
  createdRequests Request[]    @relation("CreatedBy")
  reviewedRequests Request[]   @relation("ReviewedBy")

  // Concierge service requests (renter creates, OR admin creates on
  // their behalf when guest phoned/messaged outside the portal).
  requestedServices ServiceRequest[] @relation("ServiceRequestedBy")

  // OWNER side
  ownedProperties OwnedProperty[]

  // Future ADDITIONAL_GUEST link
  guestProfile Guest? @relation("AdditionalGuestUser")

  // Audit
  auditLogs AuditLog[]

  @@index([role])
}

model OwnedProperty {
  id               String   @id @default(cuid())
  ownerUserId      String
  propertySanityId String
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, propertySanityId])
  @@index([propertySanityId])
}

model Invitation {
  id String @id @default(cuid())

  email     String
  firstName String?
  lastName  String?

  // Stay this invitation is for
  propertySanityId String
  propertyTitle    String      // snapshot for email + fallback display
  checkIn          DateTime    @db.Date
  checkOut         DateTime    @db.Date
  guestCount       Int?
  notes            String?     @db.Text

  // Magic-link surface — Clerk handles auth, we use this token to map an
  // unauthenticated visitor → this specific Invitation row on accept.
  token     String   @unique @default(cuid())
  expiresAt DateTime

  status     InvitationStatus @default(PENDING)
  acceptedAt DateTime?

  createdByUserId String
  createdBy       User     @relation("CreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  // Set when accepted — the booking we created from this invite
  resultingBookingId String?  @unique
  resultingBooking   Booking? @relation(fields: [resultingBookingId], references: [id])

  @@index([status])
  @@index([email])
}

model Booking {
  id String @id @default(cuid())

  propertySanityId String
  propertyTitle    String // snapshot at creation; protects against Sanity edits/deletes

  // Primary booking contact (Clerk-authenticated). Other guests live in `guests[]`.
  primaryGuestUserId String
  primaryGuest       User   @relation("BookingPrimaryGuest", fields: [primaryGuestUserId], references: [id])

  checkIn    DateTime      @db.Date
  checkOut   DateTime      @db.Date
  guestCount Int?
  status     BookingStatus @default(CONFIRMED)

  // Light financial picture — full ledger is out of scope for v1
  totalAmount Decimal? @db.Decimal(10, 2)
  currency    String   @default("USD")
  balanceDue  Decimal? @db.Decimal(10, 2)
  paidInFull  Boolean  @default(false)

  arrivalDetails String? @db.Text // flight info etc, guest-editable
  internalNotes  String? @db.Text // admin-only

  // Key handoff — released 24h before checkIn by daily cron
  keyCode       String?
  keyReleasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitation      Invitation?
  guests          Guest[]
  documents       Document[]
  requests        Request[]
  serviceRequests ServiceRequest[]
  notifications   Notification[]

  @@index([primaryGuestUserId])
  @@index([propertySanityId])
  @@index([status])
  @@index([checkIn])
}

model Guest {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  email       String?
  phone       String?
  dateOfBirth DateTime? @db.Date
  isMinor     Boolean   @default(false)
  isPrimary   Boolean   @default(false)
  notes       String?   @db.Text

  // Future portal access for additional guests — links to a User w/ role ADDITIONAL_GUEST
  userId String? @unique
  user   User?   @relation("AdditionalGuestUser", fields: [userId], references: [id])

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

model Request {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  kind            RequestKind
  // Bilingual snapshot of the title + description. EN is the canonical
  // field (always populated); ES is optional — when null the renter
  // portal falls back to the EN copy. Admin form pre-fills both from
  // the preset; for kind=CUSTOM the admin can fill either or both.
  title           String      // pre-filled from preset, editable; required for CUSTOM
  title_es        String?
  description     String?     @db.Text
  description_es  String?     @db.Text
  expectsDocument Boolean     @default(true)

  status RequestStatus @default(PENDING)
  dueAt  DateTime?

  fulfilledAt       DateTime?
  fulfilledByUserId String?
  fulfilledBy       User?     @relation("FulfilledBy", fields: [fulfilledByUserId], references: [id])
  textResponse      String?   @db.Text

  // Set when admin rejects a submission. Surfaced to the renter so they
  // know what to fix and re-upload. Cleared when a new submission comes in.
  reviewNote String? @db.Text
  reviewedAt DateTime?
  reviewedByUserId String?
  reviewedBy User? @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])

  documents Document[]

  createdByUserId String
  createdBy       User     @relation("CreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
}

model Document {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // Most documents respond to a request, but admin can upload unsolicited
  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  // Receipts/photos can be attached to a concierge service request
  // (most commonly: grocery receipt for a kind=GROCERY request).
  serviceRequestId String?
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  // Passports / IDs are guest-specific
  guestId String?
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  kind        DocumentKind
  filename    String       // original filename
  // R2 object key, not a public URL. Convert to signed URL at read time.
  storageKey  String
  fileSize    Int          // bytes
  contentType String
  label       String?

  // Compliance: passports/IDs auto-purged 90 days after stay end. Set when
  // the doc is created if it falls into that bucket.
  expiresAt DateTime?

  uploadedByUserId String
  uploadedBy       User     @relation("UploadedBy", fields: [uploadedByUserId], references: [id])
  uploadedAt       DateTime @default(now())

  @@index([bookingId])
  @@index([requestId])
  @@index([serviceRequestId])
  @@index([guestId])
  @@index([expiresAt])
}

model ServiceRequest {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // What KIND of request this is. Drives which fields below are populated
  // and how the renter / admin UI renders it.
  kind ServiceRequestKind @default(SERVICE)

  // Bridge to Sanity's conciergeService doc (kind=SERVICE). Snapshot the
  // slug + name + category so the booking history reads cleanly even if
  // the service is renamed/deleted in Sanity later.
  serviceSanityId String?
  serviceSlug     String?
  serviceName     String
  serviceCategory String?

  // Bridge to Sanity's presetMenu doc (kind=MENU). Same snapshotting
  // rationale as serviceSanityId.
  menuSanityId String?
  menuName     String?

  // Snapshotted shopping list for kind=GROCERY. Array of objects shaped
  // like { slug, name_en, name_es, qty, unit, brand, category, note }.
  // Stored as JSON because line-item structure evolves and we don't want
  // a join table for an ordered list that's only read in context.
  groceryItems Json?

  status ServiceRequestStatus @default(REQUESTED)

  // Renter-supplied context. Loose on purpose — half of these come in
  // as "Friday evening, 4 of us, no shellfish".
  preferredDate DateTime? @db.Date
  preferredTime String?
  partySize     Int?
  notes         String?   @db.Text

  // Admin-only working notes (vendor confirmations, prices, etc.)
  internalNotes String? @db.Text

  // Optional financial track. Quoting flow is out of scope for v1.
  quotedAmount Decimal? @db.Decimal(10, 2)
  currency     String?  @default("USD")

  // True when an admin logged the request on the renter's behalf
  // (phoned in, asked at check-in, WhatsApp). Distinguishes
  // portal submissions from out-of-band ones.
  addedManually Boolean @default(false)

  requestedByUserId String
  requestedBy       User   @relation("ServiceRequestedBy", fields: [requestedByUserId], references: [id])

  confirmedAt DateTime?
  completedAt DateTime?

  // Receipts (and any other docs) the admin uploads scoped to this
  // request — e.g. proof of grocery purchase. Document.serviceRequestId
  // is the FK; SetNull keeps the doc around if the request is deleted.
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  @@index([kind])
}

model Notification {
  id String @id @default(cuid())

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  recipientEmail  String
  recipientUserId String?

  kind    String // "invitation" | "request_created" | "request_fulfilled" | etc.
  subject String
  body    String @db.Text

  resendId String? // for tracking deliveries via Resend's API
  status   String  // "sent" | "delivered" | "failed"

  sentAt DateTime @default(now())

  @@index([bookingId])
  @@index([recipientUserId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  // Polymorphic — entity is "booking" | "request" | "document" | etc.
  entity   String
  entityId String
  action   String   // "created" | "updated" | "status_changed" | "downloaded"
  payload  Json?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorUserId])
}
